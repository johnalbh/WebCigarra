{
  "kind": "collectionType",
  "collectionName": "videos",
  "info": {
    "singularName": "video",
    "pluralName": "videos",
    "displayName": "Video",
    "description": "YouTube videos published by Fundación Cigarra"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "youtubeId": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": { "localized": false }
      }
    },
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "description": {
      "type": "text",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "category": {
      "type": "enumeration",
      "enum": ["highlight", "program", "event", "story"],
      "pluginOptions": {
        "i18n": { "localized": false }
      }
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "pluginOptions": {
        "i18n": { "localized": false }
      }
    },
    "order": {
      "type": "integer",
      "default": 0,
      "pluginOptions": {
        "i18n": { "localized": false }
      }
    }
  }
}
